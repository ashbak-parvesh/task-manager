# ============================================================
#  .env.example – FastAPI Task Manager
#  Copy this file to .env and fill in your own values.
#
#  cp .env.example .env
#
#  NEVER commit your real .env file to version control.
#  .env is already listed in .gitignore.
# ============================================================


# ------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------

# Display name shown in API docs and health-check response
APP_NAME="FastAPI Task Manager"

# Application version (shown in /docs and /health)
APP_VERSION="1.0.0"

# Set to true to enable SQLAlchemy query logging (development only)
DEBUG=false


# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# SQLite (default – fine for development and single-server deploys)
DATABASE_URL="sqlite+aiosqlite:///./task_manager.db"

# PostgreSQL example (recommended for production):
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/taskmanager"

# Docker volume path (used inside the container):
# DATABASE_URL="sqlite+aiosqlite:////data/task_manager.db"


# ------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------

# !! REQUIRED !!
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Replace the placeholder below before running the app.
SECRET_KEY="CHANGE_ME_generate_a_long_random_secret_key_here"

# Signing algorithm – HS256 is standard; do not change unless you
# know what you are doing.
ALGORITHM="HS256"

# Token lifetime in minutes (default 60 = 1 hour)
# Reduce for higher-security environments, increase for convenience.
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ------------------------------------------------------------
# CORS  (Cross-Origin Resource Sharing)
# ------------------------------------------------------------

# Comma-separated list of allowed origins.
# Use ["*"] only during local development.
#
# Single origin example:
#   ALLOWED_ORIGINS=["https://myapp.example.com"]
#
# Multiple origins example:
#   ALLOWED_ORIGINS=["https://app.example.com","https://admin.example.com"]
ALLOWED_ORIGINS=["*"]


# ------------------------------------------------------------
# UVICORN SERVER  (optional – used when running directly)
# ------------------------------------------------------------

# Host and port for local development
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8000

# Number of worker processes
# Keep at 1 for SQLite (no concurrent writers).
# Increase only when using PostgreSQL or another concurrent-safe DB.
# UVICORN_WORKERS=1